import { NextRequest, NextResponse } from 'next/server';

// ─── Config ───────────────────────────────────────────────────────────────────
const SUPABASE_ENDPOINT =
  process.env.SUPABASE_ENDPOINT ||
  'https://idoosovuatkqfrkuyiie.supabase.co/rest/v1/register_premium';

