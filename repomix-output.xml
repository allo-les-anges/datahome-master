                  color: showDark ? '#f1f5f9' : '#1e293b'
                }}
              >
                {item.value}
              </span>
              <span 
                className="text-[8px] uppercase tracking-wider text-slate-500"
                style={{ fontFamily: `${fontFamily}, sans-serif` }}
