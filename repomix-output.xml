create table public.agency_settings (
  id uuid not null default gen_random_uuid (),
  created_at timestamp with time zone not null default timezone ('utc'::text, now()),
  agency_name text not null,
  subdomain text not null,
  package_level text null default 'bronze'::text,
  logo_url text null,
  font_family text null default 'Inter, sans-serif'::text,
  primary_color text null default '#10b981'::text,
  hero_type text null default 'image'::text,
  hero_url text null,
  hero_title text null,
  modules_active jsonb null default '{"contact_page": true, "project_tracker": false}'::jsonb,
  footer_config jsonb null default '{"email": "contact@agency.com", "phone": "+34 000 00 00 00", "address": "Calle Mayor, Alicante", "socials": {"linkedin": "", "instagram": ""}}'::jsonb,
  filter_config jsonb null default '{"minCommission": 0, "excludedPromoters": []}'::jsonb,
  constraint agency_settings_pkey primary key (id),
  constraint agency_settings_subdomain_key unique (subdomain),
  constraint agency_settings_hero_type_check check (
    (
      hero_type = any (array['image'::text, 'video'::text])
    )
  ),
  constraint agency_settings_package_level_check check (
    (
      package_level = any (
        array['bronze'::text, 'silver'::text, 'gold'::text]
      )
    )
  )
) TABLESPACE pg_default;

create table public.chantier_updates (
  id uuid not null default gen_random_uuid (),
  project_id uuid null,
  image_url text not null,
  description text null,
  created_at timestamp with time zone null default now(),
  agency_id uuid null,
  constraint chantier_updates_pkey primary key (id),
  constraint chantier_updates_agency_id_fkey foreign KEY (agency_id) references agency_settings (id) on delete CASCADE
) TABLESPACE pg_default;

create table public.constats - photos (
  url_image text null,
  note_expert text null,
  created_at date null,
  id_projet uuid null,
  id uuid not null default gen_random_uuid (),
  agency_id uuid null,
  constraint constats - photos_pkey primary key (id),
  constraint constats - photos_agency_id_fkey foreign KEY (agency_id) references agency_settings (id) on delete CASCADE,
  constraint constats - photos_id_projet_fkey foreign KEY (id_projet) references suivi_chantier (id) on delete CASCADE
) TABLESPACE pg_default;

create trigger on_constat_added
after INSERT on "constats-photos" for EACH row
execute FUNCTION notify_new_constat ();

create trigger send_to_make
after INSERT on "constats-photos" for EACH row
execute FUNCTION supabase_functions.http_request (
  'https://hook.eu2.make.com/8fzzf8ccoc42b99wuqxfs4o7rbn7vn6w',
  'POST',
  '{"Content-type":"application/json"}',
  '{}',
  '5000'
);

create table public.documents_projets (
  id uuid not null default gen_random_uuid (),
  projet_id uuid null,
  nom_fichier text null,
  url_fichier text null,
  storage_path text null,
  created_at timestamp with time zone null default now(),
  type text null,
  agency_id uuid null,
  constraint documents_projets_pkey primary key (id),
  constraint documents_projets_agency_id_fkey foreign KEY (agency_id) references agency_settings (id) on delete CASCADE,
