/* ═══════════════════════════════════════════════════
   CHAT ANIMATION
═══════════════════════════════════════════════════ */
let chatGen = 0;

function sleep(ms, gen) {
  return new Promise(resolve => {
    const id = setTimeout(resolve, ms);
    const check = setInterval(() => { if (chatGen !== gen) { clearTimeout(id); clearInterval(check); resolve(); } }, 60);
    setTimeout(() => clearInterval(check), ms + 120);
  });
}

function addBubble(from, text) {
  const body = document.getElementById('chatBody');
  const wrap = document.createElement('div');
  wrap.className = 'msg' + (from==='user'?' u':'');
  const av = document.createElement('div');
  av.className = 'mav '+(from==='bot'?'b':'u');
  av.textContent = from==='bot'?'🤖':'😊';
  const bub = document.createElement('div');
  bub.className = 'bubble '+from;
  bub.textContent = text;
  wrap.appendChild(av); wrap.appendChild(bub);
  body.appendChild(wrap);
  body.scrollTop = body.scrollHeight;
}

function showTyping() {
  const body = document.getElementById('chatBody');
  const wrap = document.createElement('div');
  wrap.className='msg'; wrap.id='typingWrap';
  const av = document.createElement('div');
  av.className='mav b'; av.textContent='🤖';
  const bub = document.createElement('div');
  bub.className='bubble bot';
  bub.innerHTML='<div class="td-wrap"><div class="td"></div><div class="td"></div><div class="td"></div></div>';
  wrap.appendChild(av); wrap.appendChild(bub);
  body.appendChild(wrap);
  body.scrollTop = body.scrollHeight;
}

function hideTyping() { document.getElementById('typingWrap')?.remove(); }

function setInputText(text) {
  const el = document.getElementById('chatInput');
  if (!text) {
    el.textContent = T[currentLang].s1chatPlaceholder;
    el.style.color = 'rgba(255,255,255,.4)';
    return;
  }
  el.style.color = 'rgba(255,255,255,.85)';
  el.textContent = '';
  let i=0;
  const iv = setInterval(()=>{ if(i<text.length) el.textContent+=text[i++]; else clearInterval(iv); },45);
}

async function startChat() {
  const gen = ++chatGen;
  const t = T[currentLang];
  const body = document.getElementById('chatBody');
  body.innerHTML = '';
  document.getElementById('leadCard').classList.add('hidden');
  document.getElementById('chatInput').textContent = t.s1chatPlaceholder;
  document.getElementById('chatInput').style.color = 'rgba(255,255,255,.4)';

  await sleep(500, gen);
  if (chatGen !== gen) return;

  for (const step of t.s1chatSeq) {
    if (chatGen !== gen) return;
    if (step.from==='bot') {
      showTyping();
      await sleep(step.wait, gen);
      if (chatGen !== gen) return;
      hideTyping();
      addBubble('bot', step.text);
      await sleep(700, gen);
    } else {
      setInputText(step.text);
      await sleep(step.input, gen);
      if (chatGen !== gen) return;
      setInputText('');
      addBubble('user', step.text);
      await sleep(500, gen);
    }
  }

  if (chatGen !== gen) return;
  await sleep(500, gen);
  if (chatGen !== gen) return;
  document.getElementById('leadCard').classList.remove('hidden');
}

/* ═══════════════════════════════════════════════════
   CRM STATUS CYCLE
═══════════════════════════════════════════════════ */
let sIdx = 0;
function cycleSana() {
  const t = T[currentLang];
