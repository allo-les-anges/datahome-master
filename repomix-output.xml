"use client";

import React, { useState, useEffect } from 'react';
import { Loader2, SearchX } from "lucide-react";
import PropertyCard from './PropertyCard';

interface PropertyGridProps {
  activeFilters: any;
}

export default function PropertyGrid({ activeFilters }: PropertyGridProps) {
  const [properties, setProperties] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);

  // Simulation ou appel API
  useEffect(() => {
    const fetchProperties = async () => {
      setLoading(true);
      try {
        // Remplacez par votre appel API réel si nécessaire
        // Ici, on simule un chargement rapide
        const mockData = [
          { id: 1, title: "Villa de Luxe", location: "Dénia", price: 1250000, bedrooms: 4, bathrooms: 3, surface: 250, type: "Villa", images: [] },
          { id: 2, title: "Appartement Vue Mer", location: "Altea", price: 450000, bedrooms: 2, bathrooms: 2, surface: 95, type: "Appartement", images: [] },
          { id: 3, title: "Finca Traditionnelle", location: "Javea", price: 890000, bedrooms: 5, bathrooms: 4, surface: 320, type: "Finca", images: [] },
        ];
        setProperties(mockData);
      } catch (error) {
        console.error("Erreur chargement propriétés:", error);
      } finally {
        setLoading(false);
      }
    };

    fetchProperties();
  }, [activeFilters]);

  if (loading) {
    return (
      <div className="flex flex-col items-center justify-center py-20 space-y-4">
        <Loader2 className="w-8 h-8 animate-spin text-brand-primary" />
        <p className="text-[10px] uppercase tracking-widest text-slate-400 font-bold">Chargement des biens...</p>
      </div>
    );
  }

  if (properties.length === 0) {
    return (
      <div className="flex flex-col items-center justify-center py-20 text-center">
        <SearchX className="w-12 h-12 text-slate-200 mb-4" />
        <h3 className="text-xl font-serif italic text-slate-900">Aucun bien trouvé</h3>
        <p className="text-slate-500 text-sm mt-2">Essayez de modifier vos critères de recherche.</p>
      </div>
    );
  }

  return (
    <section id="collection" className="py-12">
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {properties.map((property) => (
          <PropertyCard key={property.id} property={property} />
        ))}
      </div>
    </section>
  );
}
