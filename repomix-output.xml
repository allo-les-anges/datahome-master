<file path="public/experience.html">
<!DOCTYPE html>
<html lang="fr" dir="ltr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>HabiHub — Experience Demo</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --gold: #D4AF37; --gold-dim: rgba(212,175,55,.12); --gold-b: rgba(212,175,55,.28);
  --s50:#f8fafc;--s100:#f1f5f9;--s200:#e2e8f0;--s300:#cbd5e1;--s400:#94a3b8;
  --s500:#64748b;--s600:#475569;--s700:#334155;--s800:#1e293b;--s900:#0f172a;
  --blue:#2563eb; --green:#16a34a; --orange:#ea580c; --wa:#25D366;
}
body { font-family:'Montserrat',sans-serif; background:var(--s900); color:#fff; height:100vh; overflow:hidden; user-select:none; }

.deck { width:100vw; height:100vh; position:relative; }
.slide { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; padding:44px 60px; opacity:0; pointer-events:none; transition:opacity .45s ease,transform .45s ease; transform:translateX(50px); }
.slide.active { opacity:1; pointer-events:all; transform:none; }
.slide.out    { opacity:0; transform:translateX(-50px); }
[dir=rtl] .slide.out { transform:translateX(50px); }

.prog { position:fixed; top:0; left:0; height:3px; background:linear-gradient(90deg,var(--gold),#F0D970); transition:width .4s; z-index:200; }

.nav { position:fixed; bottom:26px; left:50%; transform:translateX(-50%); display:flex; align-items:center; gap:12px; z-index:100; background:rgba(15,23,42,.92); backdrop-filter:blur(16px); border:1px solid rgba(255,255,255,.08); border-radius:999px; padding:9px 18px; }
.nav button { background:none; border:none; cursor:pointer; color:rgba(255,255,255,.4); font-size:18px; padding:4px 10px; border-radius:999px; transition:all .2s; }
.nav button:hover { color:#fff; background:rgba(255,255,255,.1); }
.dots { display:flex; gap:6px; }
.dot { width:6px; height:6px; border-radius:999px; background:rgba(255,255,255,.2); transition:all .3s; cursor:pointer; }
.dot.active { width:22px; background:var(--gold); }
.sc { color:rgba(255,255,255,.3); font-size:10px; font-weight:700; letter-spacing:.1em; min-width:52px; text-align:center; }

/* Language switcher */
.lang-sw { position:fixed; top:16px; left:22px; display:flex; gap:4px; z-index:100; flex-wrap:wrap; max-width:200px; }
[dir=rtl] .lang-sw { left:auto; right:22px; }
.lang-btn { background:rgba(255,255,255,.07); border:1px solid rgba(255,255,255,.1); border-radius:6px; padding:4px 9px; font-family:'Montserrat',sans-serif; font-size:10px; font-weight:800; color:rgba(255,255,255,.4); cursor:pointer; transition:all .2s; letter-spacing:.06em; }
.lang-btn:hover { color:#fff; background:rgba(255,255,255,.12); }
.lang-btn.active { background:rgba(212,175,55,.2); border-color:rgba(212,175,55,.4); color:var(--gold); }

.kb { position:fixed; top:18px; right:22px; font-size:10px; color:rgba(255,255,255,.2); font-weight:700; z-index:100; }
[dir=rtl] .kb { right:auto; left:22px; }
kbd { background:rgba(255,255,255,.07); border:1px solid rgba(255,255,255,.1); border-radius:4px; padding:2px 6px; }

/* Layout */
.two-col { display:grid; grid-template-columns:1fr 1fr; gap:48px; align-items:center; max-width:1100px; width:100%; }
.three-col { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; max-width:1100px; width:100%; }
.center-col { display:flex; flex-direction:column; align-items:center; text-align:center; max-width:820px; width:100%; }

.tag { display:inline-flex; align-items:center; gap:6px; font-size:9px; font-weight:900; letter-spacing:.2em; text-transform:uppercase; padding:5px 14px; border-radius:999px; margin-bottom:14px; }
.tg  { background:var(--gold-dim); color:var(--gold); border:1px solid var(--gold-b); }
.tb  { background:rgba(37,99,235,.12); color:#60a5fa; border:1px solid rgba(37,99,235,.3); }
.to  { background:rgba(234,88,12,.12); color:#fb923c; border:1px solid rgba(234,88,12,.3); }

.h1 { font-size:clamp(38px,5vw,66px); font-weight:900; line-height:1.05; }
.h2 { font-size:clamp(26px,3.2vw,44px); font-weight:900; line-height:1.1; }
.sub { font-size:13px; color:rgba(255,255,255,.48); font-weight:500; line-height:1.65; margin-top:10px; }
.gold { color:var(--gold); }

.steps { list-style:none; display:flex; flex-direction:column; gap:11px; margin-top:20px; }
.step { display:flex; align-items:flex-start; gap:12px; }
.sn { width:26px; height:26px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:11px; font-weight:900; color:#fff; flex-shrink:0; margin-top:1px; }
.st { font-size:13px; color:rgba(255,255,255,.6); font-weight:500; line-height:1.5; }
.st strong { color:#fff; font-weight:800; }

.note { display:flex; align-items:flex-start; gap:10px; background:var(--gold-dim); border:1px solid var(--gold-b); border-radius:14px; padding:12px 16px; margin-top:18px; }
.nt { font-size:12px; color:rgba(255,255,255,.6); font-weight:500; line-height:1.5; }
.nt strong { color:#fff; }

/* Hero */
.hero-bg { position:absolute; inset:0; background:radial-gradient(ellipse at 18% 55%,rgba(212,175,55,.08) 0%,transparent 48%),radial-gradient(ellipse at 82% 30%,rgba(37,99,235,.06) 0%,transparent 48%),linear-gradient(135deg,#090f1e 0%,#0f172a 55%,#070d1a 100%); }
.hero-inner { position:relative; z-index:1; text-align:center; max-width:760px; }
.hero-badge { display:inline-flex; align-items:center; gap:8px; background:rgba(212,175,55,.1); border:1px solid rgba(212,175,55,.22); border-radius:999px; padding:7px 18px; margin-bottom:30px; color:var(--gold); font-size:10px; font-weight:800; letter-spacing:.18em; animation:fadeUp .6s .1s both; }
.hero-title-wrap { animation:fadeUp .7s .25s both; }
.hero-sub-el { animation:fadeUp .7s .4s both; max-width:500px; margin:0 auto; }
.hero-chips { display:flex; gap:10px; justify-content:center; flex-wrap:wrap; margin-top:32px; animation:fadeUp .7s .55s both; }
.chip { display:flex; align-items:center; gap:8px; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.09); border-radius:12px; padding:9px 16px; color:rgba(255,255,255,.6); font-size:11px; font-weight:700; }
.hero-cta { margin-top:40px; animation:fadeUp .7s .7s both; }
.btn-gold { display:inline-flex; align-items:center; gap:8px; background:var(--gold); color:#000; border:none; border-radius:14px; padding:13px 26px; font-family:'Montserrat',sans-serif; font-size:13px; font-weight:900; letter-spacing:.06em; cursor:pointer; transition:transform .2s,box-shadow .2s; }
.btn-gold:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(212,175,55,.3); }

/* Phone / Chat */
.phone { width:320px; border-radius:40px; background:#111827; border:7px solid #1a2436; box-shadow:0 28px 80px rgba(0,0,0,.65); overflow:hidden; flex-shrink:0; margin:0 auto; }
.phone-notch { height:26px; background:#111827; display:flex; align-items:center; justify-content:center; }
.notch-pill { width:72px; height:5px; background:#1f2937; border-radius:999px; }
.ch-header { background:#0a1628; padding:11px 14px; display:flex; align-items:center; gap:10px; border-bottom:1px solid rgba(255,255,255,.05); }
.ch-av { width:32px; height:32px; border-radius:10px; background:var(--gold); display:flex; align-items:center; justify-content:center; font-size:15px; flex-shrink:0; }
.ch-name { font-size:12px; font-weight:800; color:#fff; }
.ch-status { font-size:8px; color:rgba(255,255,255,.38); }
.ch-body { padding:12px; display:flex; flex-direction:column; gap:9px; min-height:310px; max-height:310px; overflow:hidden; }
.msg { display:flex; gap:6px; align-items:flex-end; }
.msg.u { flex-direction:row-reverse; }
.bubble { max-width:80%; padding:9px 13px; font-size:11px; font-weight:500; line-height:1.5; border-radius:18px; animation:msgIn .28s both; }
.bubble.bot  { background:rgba(255,255,255,.08); color:rgba(255,255,255,.85); border:1px solid rgba(255,255,255,.06); border-bottom-left-radius:4px; }
.bubble.user { background:var(--gold); color:#000; font-weight:700; border-bottom-right-radius:4px; }
.mav { width:22px; height:22px; border-radius:7px; display:flex; align-items:center; justify-content:center; font-size:10px; flex-shrink:0; }
.mav.b { background:rgba(255,255,255,.1); }
.mav.u { background:var(--gold); }
.ch-inp-bar { display:flex; align-items:center; gap:7px; padding:9px 11px; background:#0a1628; border-top:1px solid rgba(255,255,255,.05); }
.ch-field { flex:1; background:rgba(255,255,255,.07); border:1px solid rgba(255,255,255,.1); border-radius:999px; padding:6px 12px; font-size:10px; color:rgba(255,255,255,.4); font-family:'Montserrat',sans-serif; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.ch-send { width:28px; height:28px; border-radius:50%; background:var(--gold); border:none; font-size:11px; cursor:pointer; flex-shrink:0; }
.td-wrap { display:flex; align-items:center; gap:3px; padding:10px 12px; }
.td { width:5px; height:5px; border-radius:50%; background:rgba(255,255,255,.45); }
.td:nth-child(1){animation:bounce 1.2s .0s infinite;}
.td:nth-child(2){animation:bounce 1.2s .2s infinite;}
.td:nth-child(3){animation:bounce 1.2s .4s infinite;}

.lead-box { width:306px; margin:10px auto 0; background:rgba(22,163,74,.1); border:1px solid rgba(22,163,74,.25); border-radius:14px; padding:12px 14px; animation:slideUp .4s both; }
.lr { display:flex; justify-content:space-between; align-items:center; margin-bottom:5px; }
.lk { font-size:8px; font-weight:900; letter-spacing:.12em; color:rgba(255,255,255,.38); text-transform:uppercase; }
.lv { font-size:10px; font-weight:700; color:#fff; }
.lsaved { display:flex; align-items:center; gap:5px; font-size:9px; font-weight:800; color:#4ade80; margin-top:7px; }

.feats { display:flex; flex-direction:column; gap:12px; margin-top:20px; }
.fi { display:flex; align-items:flex-start; gap:11px; padding:13px 15px; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.07); border-radius:13px; }
.fi-icon { font-size:20px; flex-shrink:0; }
.fi-title { font-size:12px; font-weight:800; color:#fff; }
.fi-desc { font-size:11px; color:rgba(255,255,255,.45); margin-top:2px; }

/* Search */
.search-demo { background:#fff; border-radius:22px; padding:18px; color:var(--s800); }
.sbar { display:flex; align-items:center; gap:9px; background:var(--s50); border:1.5px solid var(--s200); border-radius:999px; padding:9px 16px; margin-bottom:16px; }
.sbar input { flex:1; border:none; outline:none; font-family:'Montserrat',sans-serif; font-size:12px; color:var(--s500); background:transparent; }
.sbtn { background:var(--gold); color:#fff; border:none; border-radius:999px; padding:7px 16px; font-family:'Montserrat',sans-serif; font-size:11px; font-weight:800; cursor:pointer; }
.fg { display:grid; grid-template-columns:1fr 1fr; gap:9px; margin-bottom:14px; }
.fi2 { background:var(--s50); border:1px solid var(--s200); border-radius:12px; padding:8px 11px; }
.fi2.on { border-color:var(--gold); background:rgba(212,175,55,.06); }
.fl { font-size:8px; font-weight:900; letter-spacing:.12em; color:var(--s400); text-transform:uppercase; margin-bottom:2px; }
.fv { font-size:12px; font-weight:700; color:var(--s700); }
.fi2.on .fv { color:var(--gold); }
.price-tr { height:3px; background:var(--s100); border-radius:99px; position:relative; margin:12px 0 6px; }
.price-fl { position:absolute; left:15%; right:35%; height:100%; background:var(--gold); border-radius:99px; }
.price-th { position:absolute; width:13px; height:13px; border-radius:50%; background:#fff; border:2px solid var(--gold); top:50%; transform:translateY(-50%); box-shadow:0 2px 5px rgba(0,0,0,.15); }
.prop-g { display:grid; grid-template-columns:1fr 1fr; gap:9px; }
.pc { border-radius:14px; border:1px solid var(--s100); overflow:hidden; background:#fff; }
.pimg { height:76px; position:relative; }
.pov { position:absolute; inset:0; background:linear-gradient(to top,rgba(0,0,0,.3) 0%,transparent 55%); }
.pbadge { position:absolute; top:6px; left:6px; background:rgba(255,255,255,.9); border-radius:999px; padding:2px 7px; font-size:8px; font-weight:900; color:var(--s700); }
.pbody { padding:8px 10px; }
.pname { font-size:10px; font-weight:800; color:var(--s900); }
.ploc  { font-size:8px; color:var(--s400); margin-bottom:3px; }
.pprice { font-size:12px; font-weight:900; color:var(--gold); }
.pspecs { display:flex; gap:7px; margin-top:3px; }
.pspec { font-size:8px; color:var(--s400); font-weight:700; }

/* Mon Espace */
.me-box { background:#fff; border-radius:22px; overflow:hidden; color:var(--s800); }
.me-hdr { padding:11px 16px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid var(--s100); }
.me-logo { display:flex; align-items:center; gap:8px; }
.me-ic { width:28px; height:28px; border-radius:8px; background:var(--gold); display:flex; align-items:center; justify-content:center; font-size:13px; }
.me-nm { font-size:11px; font-weight:800; color:var(--s900); }
.me-bd { font-size:7px; font-weight:700; letter-spacing:.1em; color:var(--s400); text-transform:uppercase; }
.me-acts { display:flex; gap:5px; }
.me-act { border:1px solid var(--s200); border-radius:999px; padding:4px 10px; font-size:8px; font-weight:800; color:var(--s600); background:#fff; }
.me-body { padding:14px; }
.me-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; }
.me-ttl { font-size:16px; font-weight:900; color:var(--s900); }
.me-cnt { font-size:9px; color:var(--s400); }
.me-add { display:flex; align-items:center; gap:5px; background:var(--gold); color:#fff; border:none; border-radius:10px; padding:7px 12px; font-size:9px; font-weight:900; cursor:pointer; }
.me-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:7px; }
.mc { border-radius:12px; overflow:hidden; border:1px solid var(--s100); background:#fff; }
.mci { height:58px; }
.mcb { padding:7px 8px; }
.mcn { font-size:8px; font-weight:800; color:var(--s900); }
.mcl { font-size:7px; color:var(--s400); }
.mcp { font-size:11px; font-weight:900; }
.mca { display:flex; gap:3px; margin-top:4px; padding-top:4px; border-top:1px solid var(--s50); }
.mcb2 { flex:1; display:flex; align-items:center; justify-content:center; padding:3px; border-radius:7px; font-size:7px; font-weight:800; border:none; cursor:pointer; }
.aw { display:flex; flex-direction:column; align-items:center; text-align:center; padding:22px 18px; }
.aw-icon { width:44px; height:44px; border-radius:13px; background:rgba(212,175,55,.1); display:flex; align-items:center; justify-content:center; font-size:20px; margin-bottom:11px; }
.aw-title { font-size:16px; font-weight:900; color:var(--s900); margin-bottom:4px; }
.aw-sub   { font-size:10px; color:var(--s400); margin-bottom:16px; }
.aw-inp   { width:100%; border:1px solid var(--s200); border-radius:11px; background:var(--s50); padding:9px 13px; font-size:11px; font-family:'Montserrat',sans-serif; outline:none; letter-spacing:.2em; margin-bottom:9px; }
.aw-btn   { width:100%; border:none; border-radius:11px; padding:10px; font-family:'Montserrat',sans-serif; font-size:11px; font-weight:900; color:#fff; background:var(--gold); cursor:pointer; }

/* Mini CRM */
.crm-box { background:#fff; border-radius:22px; padding:16px; color:var(--s800); }
.ls { display:grid; grid-template-columns:repeat(4,1fr); gap:7px; margin-bottom:11px; }
.ls-card { background:var(--s50); border:1px solid var(--s100); border-radius:12px; padding:9px 11px; }
.ls-label { font-size:7px; font-weight:900; letter-spacing:.12em; text-transform:uppercase; color:var(--s400); margin-bottom:2px; }
.ls-val { font-size:20px; font-weight:900; }
.lf { display:flex; gap:5px; margin-bottom:11px; flex-wrap:wrap; }
.lf-pill { padding:5px 11px; border-radius:999px; font-size:8px; font-weight:800; border:1px solid var(--s200); color:var(--s600); cursor:pointer; }
.lf-pill.on { color:#fff; border-color:transparent; }
.ll { display:flex; flex-direction:column; gap:6px; }
.li { background:#fff; border:1px solid var(--s100); border-radius:13px; padding:9px 11px; display:flex; align-items:flex-start; gap:9px; }
.lav { width:30px; height:30px; border-radius:9px; display:flex; align-items:center; justify-content:center; color:#fff; font-size:12px; font-weight:800; flex-shrink:0; }
.lnm { font-size:10px; font-weight:800; color:var(--s900); }
.lct { font-size:8px; color:var(--s400); margin-top:1px; }
.lmeta { display:flex; gap:7px; margin-top:3px; }
.ltag { font-size:7px; font-weight:700; color:var(--s500); }
.lbadge { padding:3px 9px; border-radius:999px; font-size:7px; font-weight:900; letter-spacing:.08em; text-transform:uppercase; cursor:pointer; transition:all .2s; }
.b-new  { background:#dbeafe; color:#1d4ed8; }
.b-cont { background:#fef3c7; color:#92400e; }
.b-conv { background:#dcfce7; color:#15803d; }

/* Recap */
.rc { padding:20px; border-radius:18px; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.08); text-align:left; }
.rc-icon { font-size:26px; margin-bottom:9px; }
.rc-title { font-size:13px; font-weight:900; color:#fff; margin-bottom:5px; }
.rc-desc  { font-size:10px; color:rgba(255,255,255,.42); line-height:1.65; }

@keyframes fadeUp { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:none} }
@keyframes slideUp { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:none} }
@keyframes msgIn   { from{opacity:0;transform:translateY(8px)}  to{opacity:1;transform:none} }
@keyframes bounce  { 0%,60%,100%{transform:translateY(0)} 30%{transform:translateY(-5px)} }

.hidden { display:none !important; }

/* ── RESPONSIVE ─────────────────────────────────── */

/* Small desktop / large tablet landscape */
@media (max-width: 1100px) {
  .two-col { gap: 28px; }
  .three-col { gap: 10px; }
  .phone { width: 280px; }
  .lead-box { width: 266px; }
}

/* Tablet landscape (ex: iPad Pro 1024px) */
@media (max-width: 1024px) {
  .slide { padding: 36px 36px 88px; }
  .two-col { gap: 22px; }
  .phone { width: 260px; }
  .lead-box { width: 246px; }
  .h2 { font-size: clamp(22px,3vw,36px); }
  .sub { font-size: 12px; }
  .st { font-size: 12px; }
  .fi { padding: 10px 12px; }
  .fi-title { font-size: 11px; }
  .fi-desc { font-size: 10px; }
  .three-col { grid-template-columns: repeat(2,1fr); }
  .rc { padding: 16px; }
  .ch-body { min-height: 260px; max-height: 260px; }
  .crm-box { font-size: 12px; }
  .ls-val { font-size: 18px; }
}

/* Tablet portrait (ex: iPad 768px) */
@media (max-width: 820px) {
  .slide { padding: 66px 22px 88px; align-items: flex-start; overflow-y: auto; }
  .two-col { grid-template-columns: 1fr; gap: 20px; }
  .center-col { text-align: left; align-items: flex-start; }
  /* Re-center hero */
  #s0 .hero-inner { text-align: center; margin: 0 auto; }
  #s0 .hero-chips { justify-content: center; }
  #s0 .hero-cta   { text-align: center; }
  /* Chatbot: phone full width, feats above */
  .s1-feat-col { order: 1; }
  #s1 .two-col > div:last-child { order: 2; }
  .phone { width: 100%; max-width: 340px; margin: 0 auto; }
  .lead-box { width: 100%; max-width: 340px; }
  /* Search */
  .prop-g { grid-template-columns: 1fr 1fr; }
  /* Mon Espace */
  .me-grid { grid-template-columns: repeat(3,1fr); }
  /* CRM */
  .ls { gap: 6px; }
  .ls-val { font-size: 18px; }
  /* Recap */
  .three-col { grid-template-columns: 1fr 1fr; gap: 10px; }
  /* Lang switcher */
  .lang-sw { gap: 4px; }
  .lang-btn { padding: 3px 8px; font-size: 9px; }
  /* Nav */
  .sc { display: none; }
}

/* Large phone / small tablet */
@media (max-width: 600px) {
  .slide { padding: 58px 14px 82px; }
  .h1 { font-size: clamp(26px,7vw,38px); }
  .h2 { font-size: clamp(20px,6vw,28px); }
  .sub { font-size: 11px; }
  .hero-badge { font-size: 8px; letter-spacing: .1em; padding: 6px 14px; }
  .chip { font-size: 10px; padding: 7px 12px; }
  /* Hide feats list on chatbot slide — phone animation tells the story */
  .s1-feat-col { display: none; }
  /* Limit phone height */
  .ch-body { min-height: 240px; max-height: 240px; }
  /* CRM stats 2x2 */
  .ls { grid-template-columns: repeat(2,1fr); }
  /* Me grid 2 cols */
