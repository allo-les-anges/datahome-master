// app/api/property/[id]/route.ts
import { createClient } from '@supabase/supabase-js';
import { NextResponse } from 'next/server';

const supabase = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL!,
  process.env.SUPABASE_SERVICE_ROLE_KEY!
);

export const dynamic = 'force-dynamic';

export async function GET(
  request: Request,
  { params }: { params: { id: string } }
) {
  try {
    const { searchParams } = new URL(request.url);
    const lang = searchParams.get('lang') || 'fr';
    const supportedLangs = ['fr', 'en', 'es', 'nl', 'pl', 'ar'];
    const selectedLang = supportedLangs.includes(lang) ? lang : 'fr';

    const id = params.id;

    // Requête : on cherche par id_externe ou id (uuid)
    let query = supabase
      .from('villas')
      .select('*')
      .or(`id_externe.eq.${id},id.eq.${id}`)
      .single();

    const { data: property, error } = await query;

    if (error || !property) {
      return NextResponse.json({ error: 'Property not found' }, { status: 404 });
    }

    // Transformer pour la langue
    const formatted = {
      ...property,
      titre: property[`titre_${selectedLang}`] || property.titre_fr,
      description: property[`description_${selectedLang}`] || property.description_fr,
      // On supprime les champs bruts si on veut alléger
      titre_fr: undefined,
      titre_en: undefined,
      titre_es: undefined,
      titre_nl: undefined,
      titre_pl: undefined,
      titre_ar: undefined,
      description_fr: undefined,
      description_en: undefined,
      description_es: undefined,
      description_nl: undefined,
      description_pl: undefined,
      description_ar: undefined,
    };

    return NextResponse.json(formatted);
  } catch (error) {
    console.error('Erreur API property detail:', error);
    return NextResponse.json({ error: 'Internal Server Error' }, { status: 500 });
  }
}
