    const { data, error } = await supabase
      .from('villas')
      .select('town, region')
      .eq('is_excluded', false);

    if (error) {
      console.error("Erreur comptage régions:", error);
      return NextResponse.json({ error: "Erreur base de données" }, { status: 500 });
