<file path="OFF_middleware.ts">
import { NextResponse } from 'next/server';
import type { NextRequest } from 'next/server';

export function middleware(request: NextRequest) {
  const url = request.nextUrl;
  const hostname = request.headers.get('host') || '';

  // On définit les domaines racines (ex: localhost:3000 ou votre-saas.com)
  const rootDomain = process.env.NEXT_PUBLIC_ROOT_DOMAIN || 'localhost:3000';
  
  // Extraire le sous-domaine
  // Si hostname est "agence-era.localhost:3000", subdomain sera "agence-era"
  const subdomain = hostname.replace(`.${rootDomain}`, '');

  // 1. Éviter de traiter le domaine principal (admin, landing page)
  if (hostname === rootDomain || hostname === `www.${rootDomain}`) {
    return NextResponse.next();
  }

  // 2. Réécriture interne vers un dossier dynamique
  // Cela redirige silencieusement vers /agencies/[subdomain]/...
  return NextResponse.rewrite(
    new URL(`/agency/${subdomain}${url.pathname}`, request.url)
  );
}

export const config = {
  matcher: [
    /*
     * Matcher toutes les routes sauf API, statiques et images
     */
    '/((?!api|_next/static|_next/image|favicon.ico).*)',
  ],
};
