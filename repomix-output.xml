          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {properties.map((property) => (
              <PropertyCard 
                key={property.id} 
                property={property} 
                agency={agency} 
              />
            ))}
          </div>

          {properties.length === 0 && (
            <div className="text-center py-20">
              <p className="text-zinc-500 font-serif text-xl">
