          <div className="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-6">
            <div>
              {dev.town && (
                <p className="text-sm text-slate-500 mb-1 flex items-center gap-1.5">
                  <MapPin size={12} className="text-slate-400" />
