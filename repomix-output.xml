"use client";

import React, { useState, useEffect, useMemo } from "react";
import { RotateCcw, Search, Map, Home, Hash, Bed, X } from "lucide-react";

interface AdvancedSearchProps {
  onSearch: (filters: any) => void;
  properties?: any[];
  activeFilters?: any;
  onClose?: () => void;
  isLight?: boolean;
}

export default function AdvancedSearch({
  onSearch,
  properties = [],
  activeFilters = {}, 
  onClose,
  isLight = true,
}: AdvancedSearchProps) {
  
  // Initialisation sécurisée des filtres locaux
  const [localFilters, setLocalFilters] = useState({
    region: activeFilters?.region || "",
    town: activeFilters?.town || "",
    type: activeFilters?.type || "",
    beds: activeFilters?.beds || "",
    minPrice: activeFilters?.minPrice || "100000",
    maxPrice: activeFilters?.maxPrice || "5000000",
    reference: activeFilters?.reference || "",
  });

  // Synchronisation par comparaison de chaîne JSON pour éviter les boucles infinies
  // Le tableau de dépendances contient 1 seul élément [activeFilters]
  useEffect(() => {
    const nextFilters = {
      region: activeFilters?.region || "",
      town: activeFilters?.town || "",
      type: activeFilters?.type || "",
      beds: activeFilters?.beds || "",
      minPrice: activeFilters?.minPrice || "100000",
      maxPrice: activeFilters?.maxPrice || "5000000",
      reference: activeFilters?.reference || "",
    };

    // On ne met à jour le state local que si les données réelles ont changé
    if (JSON.stringify(localFilters) !== JSON.stringify(nextFilters)) {
      setLocalFilters(nextFilters);
    }
  }, [activeFilters]); 

  const regions = ["Costa Blanca", "Costa Calida", "Costa del Sol", "Costa Almeria"];
  
  const types = useMemo(() => {
    const translation: { [key: string]: string } = {
      villa: "Villa", 
      apartment: "Appartement", 
      penthouse: "Penthouse", 
      bungalow: "Bungalow", 
      townhouse: "Maison de ville"
    };
    const safeProps = Array.isArray(properties) ? properties : [];
    return [...new Set(safeProps.map((p) => p.type))]
      .filter((t) => t && t.toLowerCase() !== "property")
      .map((t) => ({ id: t.toLowerCase(), label: translation[t.toLowerCase()] || t }));
  }, [properties]);

  const handleSearchClick = () => {
    onSearch(localFilters);
    if (onClose) onClose();
  };

  const reset = () => {
    const empty = { 
      region: "", town: "", type: "", beds: "", 
      minPrice: "100000", maxPrice: "5000000", reference: "" 
    };
    setLocalFilters(empty);
    onSearch(empty);
  };

  return (
    <div className="max-w-7xl mx-auto px-4 relative z-[100]">
      <style jsx>{`
        .custom-slider {
          -webkit-appearance: none;
          width: 100%;
          height: 4px;
          background: #e2e8f0;
          border-radius: 5px;
          outline: none;
        }
        .custom-slider::-webkit-slider-thumb {
          -webkit-appearance: none;
          appearance: none;
          width: 20px;
          height: 20px;
          background: var(--brand-primary);
          border-radius: 50%;
          cursor: pointer;
          border: 2px solid white;
          box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
      `}</style>

      {onClose && (
        <button 
          onClick={onClose}
          className="absolute -top-6 -right-2 md:right-4 w-12 h-12 rounded-full flex items-center justify-center shadow-2xl bg-white text-slate-900 border border-slate-200 hover:bg-slate-50 transition-all z-[110]"
        >
          <X size={24} />
        </button>
      )}

      <div className="bg-white rounded-[2.5rem] shadow-[0_30px_100px_rgba(0,0,0,0.1)] border border-slate-100 p-3 relative">
        <div className="w-12 h-1.5 rounded-full mx-auto mt-2 mb-4 lg:hidden bg-slate-100" />

        <div className="border-b border-slate-50">
          <div className="p-6 lg:p-8">
            <label className="flex items-center gap-2 text-[9px] uppercase font-black tracking-[0.2em] text-slate-400 mb-2">
              <Hash size={12} className="text-brand-primary" /> Référence Propriété
            </label>
            <input 
              type="text"
              placeholder="Ex: REF-1234"
              value={localFilters.reference}
              onChange={(e) => setLocalFilters({ ...localFilters, reference: e.target.value })}
              className="w-full bg-transparent text-lg font-serif italic outline-none text-slate-900 placeholder:text-slate-300"
            />
          </div>
        </div>

        <div className="flex flex-col lg:flex-row items-stretch">
          <div className="flex-1 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-0">
            <div className="p-6 border-b lg:border-b-0 lg:border-r border-slate-50">
              <label className="flex items-center gap-2 text-[9px] uppercase font-black tracking-[0.2em] text-slate-400 mb-2">
                <Map size={12} /> Région
              </label>
              <select 
                value={localFilters.region}
                onChange={(e) => setLocalFilters({ ...localFilters, region: e.target.value })}
                className="w-full bg-transparent text-[13px] font-bold outline-none cursor-pointer appearance-none uppercase text-slate-900"
              >
                <option value="">Espagne (Toutes)</option>
                {regions.map(r => <option key={r} value={r}>{r}</option>)}
              </select>
            </div>

            <div className="p-6 border-b lg:border-b-0 lg:border-r border-slate-50">
              <label className="flex items-center gap-2 text-[9px] uppercase font-black tracking-[0.2em] text-slate-400 mb-2">
                <Home size={12} /> Type
              </label>
              <select 
                value={localFilters.type}
                onChange={(e) => setLocalFilters({ ...localFilters, type: e.target.value })}
                className="w-full bg-transparent text-[13px] font-bold outline-none cursor-pointer appearance-none uppercase text-slate-900"
              >
                <option value="">Indifférent</option>
                {types.map(t => <option key={t.id} value={t.id}>{t.label}</option>)}
              </select>
            </div>

            <div className="p-6 border-b lg:border-b-0 lg:border-r border-slate-50">
              <div className="flex justify-between items-center mb-3">
                <label className="text-[9px] uppercase font-black tracking-[0.2em] text-slate-400">Min</label>
                <span className="text-[11px] font-bold text-slate-900">
                  {parseInt(localFilters.minPrice).toLocaleString()} €
                </span>
              </div>
              <input 
                type="range"
                min="100000"
                max="2000000"
                step="50000"
                value={localFilters.minPrice}
                onChange={(e) => setLocalFilters({ ...localFilters, minPrice: e.target.value })}
                className="custom-slider"
              />
            </div>

            <div className="p-6 border-b lg:border-b-0 lg:border-r border-slate-50">
              <div className="flex justify-between items-center mb-3">
                <label className="text-[9px] uppercase font-black tracking-[0.2em] text-slate-400">Max</label>
                <span className="text-[11px] font-bold text-slate-900">
                  {parseInt(localFilters.maxPrice).toLocaleString()} €
                </span>
              </div>
              <input 
                type="range"
                min="200000"
                max="5000000"
                step="50000"
                value={localFilters.maxPrice}
                onChange={(e) => setLocalFilters({ ...localFilters, maxPrice: e.target.value })}
                className="custom-slider"
              />
            </div>

            <div className="p-6">
              <label className="flex items-center gap-2 text-[9px] uppercase font-black tracking-[0.2em] text-slate-400 mb-3">
                <Bed size={12} /> Chambres
              </label>
              <div className="flex gap-1">
                {[2, 3, 4, 5].map((n) => (
                  <button
                    key={n}
                    type="button"
                    onClick={() => setLocalFilters({ ...localFilters, beds: n.toString() })}
                    className={`flex-1 h-8 rounded-lg text-[10px] font-black transition-all ${
                      localFilters.beds === n.toString() 
                      ? "bg-slate-900 text-white" 
                      : "bg-slate-50 text-slate-400 hover:bg-slate-100"
                    }`}
                  >
                    {n}+
                  </button>
                ))}
              </div>
            </div>
          </div>

          <div className="p-4 flex items-center justify-center bg-slate-50/50 lg:rounded-r-[2.5rem]">
            <button 
              onClick={handleSearchClick}
              className="w-full lg:w-20 h-16 lg:h-20 rounded-3xl flex items-center justify-center bg-brand-primary text-white hover:scale-105 transition-all duration-300 shadow-xl"
              style={{ backgroundColor: 'var(--brand-primary)' }}
            >
              <Search size={24} strokeWidth={2.5} />
            </button>
          </div>
        </div>
      </div>

      <div className="mt-6 flex justify-between items-center px-8">
        <p className="text-[10px] font-medium italic text-slate-400">
          Sélection Exclusive • Habihub Light
        </p>
        <button 
          onClick={reset}
          className="flex items-center gap-2 text-[10px] uppercase font-bold text-slate-400 hover:text-red-500 tracking-[0.2em] transition-colors"
        >
          <RotateCcw size={12} /> Réinitialiser
        </button>
      </div>
    </div>
  );
}
</file>

