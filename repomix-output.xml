              placeholder={t('contact.placeholder_name') || "VOTRE NOM"} 
              required
              style={inputStyle}
              onFocus={(e) => {
                e.target.style.borderColor = primaryColor;
                e.target.style.boxShadow = `0 0 0 2px ${primaryColor}20`;
              }}
