      example: "/api/sync-villas?url=https://example.com/feed.xml"
    });
  }
  
  // Simuler un appel POST pour tester
  return POST(new Request(req.url, {
    method: 'POST',
    body: JSON.stringify({ xmlUrl, agencyId: 'test', agentId: 'test' })
  }));
}
