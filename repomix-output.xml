    --slate-700: #334155;
    --slate-800: #1e293b;
    --slate-900: #0f172a;
    --orange: #ea580c;
    --green: #16a34a;
    --blue: #2563eb;
  }
  body {
    font-family: 'Montserrat', sans-serif;
    background: var(--slate-900);
    color: var(--slate-800);
    height: 100vh;
    overflow: hidden;
    user-select: none;
  }

  /* ── Slides ── */
  .deck { width: 100vw; height: 100vh; position: relative; }
  .slide {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    padding: 40px;
    opacity: 0; pointer-events: none;
    transition: opacity .5s ease, transform .5s ease;
    transform: translateX(60px);
  }
  .slide.active { opacity: 1; pointer-events: all; transform: translateX(0); }
  .slide.out    { opacity: 0; transform: translateX(-60px); }

  /* ── Nav ── */
  .nav {
    position: fixed; bottom: 32px; left: 50%; transform: translateX(-50%);
    display: flex; align-items: center; gap: 16px; z-index: 100;
    background: rgba(15,23,42,.85); backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,.1); border-radius: 999px;
    padding: 10px 20px;
  }
  .nav button {
    background: none; border: none; cursor: pointer;
    color: rgba(255,255,255,.5); font-family: 'Montserrat', sans-serif;
    font-size: 12px; font-weight: 700; letter-spacing: .08em; padding: 6px 14px;
    border-radius: 999px; transition: all .2s;
  }
  .nav button:hover { color: #fff; background: rgba(255,255,255,.08); }
  .nav button.prev, .nav button.next { font-size: 18px; padding: 4px 12px; }
  .dots { display: flex; gap: 6px; align-items: center; }
  .dot {
    width: 6px; height: 6px; border-radius: 999px;
    background: rgba(255,255,255,.25); transition: all .3s; cursor: pointer;
  }
  .dot.active { width: 20px; background: var(--gold); }
  .slide-label { color: rgba(255,255,255,.35); font-size: 10px; font-weight: 700; letter-spacing: .15em; min-width: 60px; text-align: center; }

  /* ── Progress ── */
  .progress-bar {
    position: fixed; top: 0; left: 0; height: 2px;
    background: linear-gradient(90deg, var(--gold), #F0D970);
    transition: width .4s ease; z-index: 200;
  }

  /* ── Slide 0 — Intro ── */
  .slide-intro { background: linear-gradient(135deg, #0f172a 0%, #1e293b 60%, #0f2040 100%); }
  .intro-inner { text-align: center; max-width: 700px; }
  .intro-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(212,175,55,.15); border: 1px solid rgba(212,175,55,.3);
    border-radius: 999px; padding: 6px 16px; margin-bottom: 32px;
    color: var(--gold); font-size: 10px; font-weight: 800; letter-spacing: .2em;
    animation: fadeUp .6s .2s both;
  }
  .intro-title {
    font-size: clamp(36px, 5vw, 64px); font-weight: 900; color: #fff;
    line-height: 1.05; margin-bottom: 20px;
    animation: fadeUp .6s .35s both;
  }
  .intro-title span { color: var(--gold); }
  .intro-sub {
    font-size: 16px; color: var(--slate-400); font-weight: 500; margin-bottom: 48px;
    animation: fadeUp .6s .5s both;
  }
  .intro-modules {
    display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;
    animation: fadeUp .6s .65s both;
  }
  .intro-chip {
    display: flex; align-items: center; gap-8px; gap: 8px;
    background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
    border-radius: 16px; padding: 10px 18px;
    color: rgba(255,255,255,.7); font-size: 12px; font-weight: 700;
    letter-spacing: .06em;
  }
  .intro-chip .chip-icon { font-size: 16px; }

  /* ── Slide bg ── */
  .slide-light { background: var(--slate-50); }
  .slide-dark  { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); }

  /* ── Section title ── */
  .section-tag {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 9px; font-weight: 900; letter-spacing: .2em; text-transform: uppercase;
    padding: 5px 14px; border-radius: 999px; margin-bottom: 12px;
  }
  .tag-gold  { background: rgba(212,175,55,.15); color: var(--gold); border: 1px solid rgba(212,175,55,.3); }
  .tag-blue  { background: rgba(37,99,235,.1);  color: var(--blue); border: 1px solid rgba(37,99,235,.2); }
  .tag-green { background: rgba(22,163,74,.1);  color: var(--green); border: 1px solid rgba(22,163,74,.2); }
  .tag-orange{ background: rgba(234,88,12,.1);  color: var(--orange); border: 1px solid rgba(234,88,12,.2); }

  .slide-title { font-size: clamp(22px, 3vw, 36px); font-weight: 900; line-height: 1.1; }
  .slide-sub   { font-size: 13px; color: var(--slate-400); font-weight: 500; margin-top: 6px; }

  /* ── Layout helpers ── */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; max-width: 1100px; width: 100%; }
  .three-col { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; max-width: 1100px; width: 100%; }
  .left-col { display: flex; flex-direction: column; }
  .card {
    background: #fff; border-radius: 28px;
    border: 1px solid var(--slate-200); box-shadow: 0 4px 24px rgba(0,0,0,.06);
    overflow: hidden;
  }
  .card-dark { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1); border-radius: 28px; overflow: hidden; }

  /* ── Search slide ── */
  .search-bar {
    display: flex; align-items: center; gap: 10px;
    background: #fff; border: 1.5px solid var(--slate-200);
    border-radius: 999px; padding: 10px 20px; margin-bottom: 20px;
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
  }
  .search-icon { color: var(--slate-300); font-size: 16px; }
  .search-input { flex: 1; border: none; outline: none; font-family: 'Montserrat', sans-serif; font-size: 13px; color: var(--slate-500); }
  .search-btn {
    background: var(--gold); color: #fff; border: none; border-radius: 999px;
    padding: 8px 20px; font-family: 'Montserrat', sans-serif; font-size: 12px;
    font-weight: 800; letter-spacing: .08em; cursor: pointer;
  }
  .filter-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 14px; }
  .filter-item {
    background: var(--slate-50); border: 1px solid var(--slate-200);
    border-radius: 16px; padding: 10px 14px;
  }
  .filter-label { font-size: 8px; font-weight: 900; letter-spacing: .15em; color: var(--slate-400); text-transform: uppercase; margin-bottom: 3px; }
  .filter-value { font-size: 13px; font-weight: 700; color: var(--slate-700); }
  .filter-active { border-color: var(--gold); background: rgba(212,175,55,.06); }
  .filter-active .filter-value { color: var(--gold); }
  .price-range { margin-bottom: 14px; }
  .price-track { height: 4px; background: var(--slate-200); border-radius: 99px; position: relative; margin: 16px 0 8px; }
  .price-fill { position: absolute; left: 15%; right: 30%; height: 100%; background: var(--gold); border-radius: 99px; }
  .price-thumb {
    position: absolute; width: 16px; height: 16px; border-radius: 50%;
    background: #fff; border: 2.5px solid var(--gold); top: 50%; transform: translateY(-50%);
    box-shadow: 0 2px 6px rgba(0,0,0,.15);
  }
  .price-thumb.left  { left: calc(15% - 8px); }
  .price-thumb.right { right: calc(30% - 8px); }
  .price-labels { display: flex; justify-content: space-between; font-size: 10px; font-weight: 700; color: var(--slate-500); }

  /* Property cards */
  .prop-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .prop-card { border-radius: 20px; overflow: hidden; border: 1px solid var(--slate-100); background: #fff; }
  .prop-img { height: 90px; position: relative; overflow: hidden; }
  .prop-img-bg { width: 100%; height: 100%; object-fit: cover; }
  .prop-img-grad { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,.4) 0%, transparent 60%); }
  .prop-badge { position: absolute; top: 8px; left: 8px; background: rgba(255,255,255,.95); border-radius: 999px; padding: 2px 8px; font-size: 9px; font-weight: 900; letter-spacing: .08em; color: var(--slate-700); }
  .prop-body { padding: 10px 12px; }
  .prop-name { font-size: 11px; font-weight: 800; color: var(--slate-900); line-height: 1.2; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .prop-loc { font-size: 9px; color: var(--slate-400); font-weight: 600; margin-bottom: 6px; }
  .prop-price { font-size: 14px; font-weight: 900; color: var(--gold); }
  .prop-specs { display: flex; gap: 8px; margin-top: 4px; }
  .prop-spec { font-size: 9px; color: var(--slate-400); font-weight: 700; display: flex; align-items: center; gap: 3px; }

  /* Animated highlight */
  .click-hint {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 10px; font-weight: 800; letter-spacing: .1em; color: var(--gold);
    text-transform: uppercase; margin-top: 16px;
  }
  .pulse-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--gold); animation: pulse 1.5s infinite; }

  /* ── Chatbot slide ── */
  .chat-window {
    width: 100%; border-radius: 28px;
    background: #fff; border: 1px solid var(--slate-100);
    box-shadow: 0 8px 40px rgba(0,0,0,.1); overflow: hidden;
  }
  .chat-header {
    display: flex; align-items: center; gap: 10px;
    padding: 14px 18px; background: var(--slate-900); border-bottom: 1px solid rgba(255,255,255,.06);
  }
  .chat-avatar { width: 32px; height: 32px; border-radius: 10px; display: flex; align-items: center; justify-content: center; background: var(--gold); font-size: 16px; }
  .chat-name { font-size: 13px; font-weight: 800; color: #fff; }
  .chat-status { font-size: 9px; color: rgba(255,255,255,.4); font-weight: 600; letter-spacing: .08em; }
  .chat-body { padding: 16px; display: flex; flex-direction: column; gap: 10px; max-height: 260px; overflow: hidden; }
  .msg { display: flex; gap: 8px; align-items: flex-end; }
  .msg.user { flex-direction: row-reverse; }
  .msg-bubble {
    max-width: 75%; padding: 9px 14px; border-radius: 18px;
    font-size: 12px; font-weight: 500; line-height: 1.45;
  }
  .msg.bot .msg-bubble { background: var(--slate-50); color: var(--slate-700); border-bottom-left-radius: 4px; border: 1px solid var(--slate-100); }
  .msg.user .msg-bubble { color: #fff; border-bottom-right-radius: 4px; }
  .msg-icon { width: 26px; height: 26px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 13px; flex-shrink: 0; }
  .msg.bot .msg-icon { background: var(--slate-100); }
  .msg.user .msg-icon { background: var(--gold); }
  .chat-input { display: flex; align-items: center; gap: 8px; padding: 12px 16px; border-top: 1px solid var(--slate-100); }
  .chat-field { flex: 1; border: 1px solid var(--slate-200); border-radius: 999px; padding: 8px 16px; font-size: 12px; font-family: 'Montserrat', sans-serif; color: var(--slate-500); outline: none; }
  .chat-send { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: none; cursor: pointer; font-size: 14px; }

  /* Lead capture card */
  .lead-card { background: var(--slate-50); border: 1px solid var(--slate-100); border-radius: 20px; padding: 16px; margin-top: 10px; }
  .lead-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
  .lead-key { font-size: 9px; font-weight: 900; letter-spacing: .1em; color: var(--slate-400); text-transform: uppercase; }
  .lead-val { font-size: 11px; font-weight: 700; color: var(--slate-800); }
  .lead-saved { display: flex; align-items: center; gap: 6px; font-size: 10px; font-weight: 800; color: var(--green); margin-top: 10px; }

  /* ── Mon Espace slide ── */
  .me-header { padding: 14px 20px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--slate-100); background: #fff; }
  .me-logo { display: flex; align-items: center; gap: 10px; }
  .me-logo-icon { width: 32px; height: 32px; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 14px; }
  .me-logo-name { font-size: 13px; font-weight: 800; color: var(--slate-900); }
  .me-logo-badge { font-size: 8px; font-weight: 900; letter-spacing: .12em; color: var(--slate-400); text-transform: uppercase; }
  .me-actions { display: flex; gap: 8px; }
  .me-action-btn {
    display: flex; align-items: center; gap: 5px;
    border: 1px solid var(--slate-200); border-radius: 999px; padding: 6px 14px;
    font-size: 10px; font-weight: 800; color: var(--slate-600); background: #fff; cursor: pointer;
    letter-spacing: .05em;
  }
  .me-body { padding: 20px; }
  .me-stats { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .me-title { font-size: 20px; font-weight: 900; color: var(--slate-900); }
  .me-count { font-size: 11px; color: var(--slate-400); font-weight: 600; margin-top: 2px; }
  .me-add { display: flex; align-items: center; gap: 6px; border: none; border-radius: 14px; padding: 10px 16px; color: #fff; font-size: 11px; font-weight: 900; cursor: pointer; letter-spacing: .04em; }
  .me-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
  .me-card { border-radius: 18px; overflow: hidden; border: 1px solid var(--slate-100); background: #fff; }
  .me-card-img { height: 80px; background: var(--slate-100); position: relative; }
  .me-card-body { padding: 8px 10px; }
  .me-card-name { font-size: 10px; font-weight: 800; color: var(--slate-900); margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .me-card-loc { font-size: 8px; color: var(--slate-400); margin-bottom: 4px; }
  .me-card-price { font-size: 13px; font-weight: 900; }
  .me-card-actions { display: flex; gap: 4px; margin-top: 6px; padding-top: 6px; border-top: 1px solid var(--slate-50); }
  .me-card-btn { flex: 1; display: flex; align-items: center; justify-content: center; gap: 4px; padding: 5px; border-radius: 10px; font-size: 8px; font-weight: 800; border: none; cursor: pointer; }

  /* Password wall */
  .pw-wall { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 32px 24px; }
  .pw-icon { width: 52px; height: 52px; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: 16px; }
  .pw-title { font-size: 20px; font-weight: 900; color: var(--slate-900); margin-bottom: 6px; }
  .pw-sub { font-size: 12px; color: var(--slate-400); font-weight: 500; margin-bottom: 24px; }
  .pw-input { width: 100%; border: 1px solid var(--slate-200); border-radius: 16px; background: var(--slate-50); padding: 12px 16px; font-size: 13px; font-family: 'Montserrat',sans-serif; outline: none; letter-spacing: .2em; color: var(--slate-700); margin-bottom: 12px; }
  .pw-btn { width: 100%; border: none; border-radius: 16px; padding: 13px; font-size: 13px; font-family: 'Montserrat', sans-serif; font-weight: 900; color: #fff; cursor: pointer; letter-spacing: .06em; }

  /* ── Leads slide ── */
  .leads-stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; margin-bottom: 14px; }
  .stat-card { background: #fff; border: 1px solid var(--slate-100); border-radius: 18px; padding: 12px 14px; }
  .stat-label { font-size: 8px; font-weight: 900; letter-spacing: .12em; text-transform: uppercase; color: var(--slate-400); margin-bottom: 4px; }
  .stat-val { font-size: 26px; font-weight: 900; }
  .leads-filters { display: flex; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; }
  .filter-pill { padding: 6px 14px; border-radius: 999px; font-size: 10px; font-weight: 800; border: 1px solid var(--slate-200); background: #fff; color: var(--slate-600); cursor: pointer; }
  .filter-pill.active { color: #fff; border-color: transparent; }
  .leads-list { display: flex; flex-direction: column; gap: 8px; }
  .lead-item { background: #fff; border: 1px solid var(--slate-100); border-radius: 18px; padding: 12px 14px; display: flex; align-items: flex-start; gap: 12px; }
  .lead-avatar { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 14px; font-weight: 800; flex-shrink: 0; }
  .lead-name { font-size: 12px; font-weight: 800; color: var(--slate-900); }
  .lead-contact { font-size: 10px; color: var(--slate-400); margin-top: 2px; }
  .lead-meta { display: flex; gap: 10px; margin-top: 4px; }
  .lead-tag { font-size: 9px; font-weight: 700; color: var(--slate-500); }
  .lead-status { margin-left: auto; }
  .status-badge { padding: 4px 12px; border-radius: 999px; font-size: 9px; font-weight: 900; letter-spacing: .1em; text-transform: uppercase; cursor: pointer; }
  .status-new       { background: #dbeafe; color: #1d4ed8; }
  .status-contacted { background: #fef3c7; color: #92400e; }
  .status-converted { background: #dcfce7; color: #15803d; }

  /* ── Annotations ── */
  .annotation {
    display: flex; align-items: flex-start; gap: 10px;
    background: rgba(212,175,55,.08); border: 1px solid rgba(212,175,55,.2);
    border-radius: 16px; padding: 12px 16px; margin-top: 16px;
  }
  .annotation-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }
  .annotation-text { font-size: 12px; color: var(--slate-600); font-weight: 500; line-height: 1.5; }
  .annotation-text strong { color: var(--slate-800); font-weight: 800; }

  .annotation-blue {
    background: rgba(37,99,235,.06); border-color: rgba(37,99,235,.15);
  }
  .annotation-blue .annotation-text { color: var(--slate-600); }

  .annotation-orange {
    background: rgba(234,88,12,.06); border-color: rgba(234,88,12,.15);
  }

  .step-list { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-top: 16px; }
  .step-item { display: flex; align-items: flex-start; gap: 12px; }
  .step-num {
    width: 24px; height: 24px; border-radius: 8px; display: flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 900; color: #fff; flex-shrink: 0; margin-top: 1px;
  }
  .step-text { font-size: 13px; color: var(--slate-600); font-weight: 500; line-height: 1.45; }
  .step-text strong { color: var(--slate-800); font-weight: 800; }

  /* ── Animations ── */
  @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes pulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: .5; transform: scale(.7); } }
  @keyframes typing { 0%,66% { opacity: 0; } 33% { opacity: 1; } }
  @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0; } }
  @keyframes slideUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }

  .slide.active .card,
  .slide.active .chat-window,
  .slide.active .pw-wall { animation: slideUp .4s .1s both; }

  .typing-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--slate-300); margin: 0 2px; }
  .typing-dot:nth-child(1) { animation: typing 1.2s .0s infinite; }
  .typing-dot:nth-child(2) { animation: typing 1.2s .2s infinite; }
  .typing-dot:nth-child(3) { animation: typing 1.2s .4s infinite; }

  .cursor { display: inline-block; animation: blink .8s infinite; }

  /* Chip hover animated colors */
  .anim-chip { animation: fadeUp .5s both; }
  .anim-chip:nth-child(1) { animation-delay: .5s; }
  .anim-chip:nth-child(2) { animation-delay: .65s; }
  .anim-chip:nth-child(3) { animation-delay: .8s; }
  .anim-chip:nth-child(4) { animation-delay: .95s; }

  /* Dark slide text */
  .text-white { color: #fff; }
  .text-muted { color: rgba(255,255,255,.55); }

  /* Keyboard hint */
  .kb-hint { position: fixed; top: 20px; right: 24px; font-size: 10px; color: rgba(255,255,255,.25); font-weight: 700; letter-spacing: .1em; z-index: 100; }
  kbd { background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.12); border-radius: 5px; padding: 2px 7px; }
</style>
</head>
<body>

<div class="progress-bar" id="progress"></div>
<div class="kb-hint"><kbd>←</kbd> <kbd>→</kbd> naviguer</div>

<div class="deck" id="deck">

  <!-- ══════════════════════════════════════════════════════
       SLIDE 0 — INTRO
  ══════════════════════════════════════════════════════ -->
  <div class="slide slide-intro active" data-idx="0">
    <div class="intro-inner">
      <div class="intro-badge">⬡ HABIHUB LIGHT TEMPLATE &nbsp;·&nbsp; GUIDE D'UTILISATION</div>
      <h1 class="intro-title">Votre site agence<br /><span>immobilière clé en main</span></h1>
      <p class="intro-sub">Découvrez les 4 fonctionnalités principales qui font de ce template<br />un outil de prospection et de gestion au quotidien.</p>
      <div class="intro-modules">
        <div class="intro-chip anim-chip"><span class="chip-icon">🔍</span> Recherche avancée</div>
        <div class="intro-chip anim-chip"><span class="chip-icon">🤖</span> Chatbot IA qualifiant</div>
        <div class="intro-chip anim-chip"><span class="chip-icon">🏠</span> Mon Espace agence</div>
        <div class="intro-chip anim-chip"><span class="chip-icon">📊</span> Mini CRM Leads</div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════
       SLIDE 1 — RECHERCHE AVANCÉE : INTRO
  ══════════════════════════════════════════════════════ -->
  <div class="slide slide-light" data-idx="1">
    <div class="two-col">
