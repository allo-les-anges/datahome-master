          const count = regionCounts[region.name] || 0;
          return (
            <motion.div
              key={region.name}
              initial={{ opacity: 0, scale: 0.99 }}
              whileInView={{ opacity: 1, scale: 1 }}
              viewport={{ once: true }}
              transition={{ delay: index * 0.05, duration: 1, ease: [0.19, 1, 0.22, 1] }}
              onClick={() => onRegionClick(region.name)}
