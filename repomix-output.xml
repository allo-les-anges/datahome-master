    </div>
  </div>

</div><!-- /deck -->

<!-- Navigation -->
<nav class="nav">
  <button class="prev" onclick="go(-1)">‹</button>
  <div class="dots" id="dots"></div>
  <button class="next" onclick="go(1)">›</button>
  <span class="slide-label" id="label">1 / 6</span>
</nav>

<script>
  const slides = document.querySelectorAll('.slide');
  const dots   = document.getElementById('dots');
  const label  = document.getElementById('label');
  const bar    = document.getElementById('progress');
  const LABELS = ['Intro','Recherche','Chatbot','Mon Espace','Mes Leads','Récap'];
  let cur = 0;

  // Build dots
  slides.forEach((_, i) => {
    const d = document.createElement('div');
    d.className = 'dot' + (i === 0 ? ' active' : '');
    d.onclick = () => goTo(i);
    dots.appendChild(d);
  });

  function goTo(n) {
    if (n < 0 || n >= slides.length) return;
    slides[cur].classList.remove('active');
    slides[cur].classList.add('out');
    setTimeout(() => slides[cur].classList.remove('out'), 500);
    cur = n;
    slides[cur].classList.add('active');
    document.querySelectorAll('.dot').forEach((d, i) => d.classList.toggle('active', i === cur));
    label.textContent = LABELS[cur] + '  ' + (cur + 1) + ' / ' + slides.length;
    bar.style.width = ((cur + 1) / slides.length * 100) + '%';
  }

  function go(d) { goTo(cur + d); }

  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') go(1);
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   go(-1);
  });

  // Init
  bar.style.width = (1 / slides.length * 100) + '%';
  label.textContent = LABELS[0] + '  1 / ' + slides.length;
</script>
</body>
</html>
