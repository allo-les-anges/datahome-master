import { headers } from "next/headers";
import AgencyPageClient from "./AgencyPageClient"; // Assurez-vous que le chemin est bon
import { Suspense } from "react";

export const dynamic = "force-dynamic";

export default async function HomePage() {
  const headersList = await headers();
  const host = headersList.get("host") || "";
  
  // Remplacer par votre domaine exact sur Vercel sans https://
  const rootDomain = process.env.NEXT_PUBLIC_ROOT_DOMAIN || "datahome-dq5kkgxnj-mukebas-projects.vercel.app";

  let subdomain = null;
  if (host.endsWith(`.${rootDomain}`)) {
    subdomain = host.replace(`.${rootDomain}`, "");
  }

  // SI SOUS-DOMAINE DÉTECTÉ : On affiche l'agence DIRECTEMENT
  // On ne fait PAS de redirect(), on rend le composant sur la même URL
  if (subdomain && subdomain !== "www") {
    return (
      <Suspense fallback={<div>Chargement...</div>}>
        <AgencyPageClient slug={subdomain} />
      </Suspense>
    );
  }

  // SI PAS DE SOUS-DOMAINE : On affiche la page vitrine HabiHub
  return (
    <main className="flex flex-col items-center justify-center min-h-screen">
      <h1>Bienvenue sur HabiHub</h1>
      <p>Plateforme principale</p>
      {/* Ajoutez ici votre contenu pour le domaine racine */}
    </main>
  );
}
