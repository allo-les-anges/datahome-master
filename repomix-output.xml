                  className={`px-4 py-2 rounded-xl text-[10px] font-bold uppercase tracking-widest transition-all ${statusFilter === f.value ? "bg-slate-900 text-white" : "bg-slate-50 text-slate-400 hover:text-slate-700"}`}
