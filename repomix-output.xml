<file path="src/app/globals.css">
@import "tailwindcss";

/* ===== 1. VARIABLES ===== */
@layer base {
  :root {
    --background: #ffffff;
    --foreground: #0f172a;
    --accent-gold: #D4AF37;
  }

  html.dark:not([data-package="light"]) {
    --background: #020617;
    --foreground: #ffffff;
  }
}

/* ===== 2. COLOR-SCHEME ===== */
html {
  color-scheme: light;
}
html.dark:not([data-package="light"]) {
  color-scheme: dark;
}

/* ===== 3. MODE LIGHT FORCÉ (data-package="light") ===== */
html[data-package="light"] {
  /* On ne force pas de bg-color sur HTML pour ne pas bloquer le Hero */
  color: #0f172a !important;
}

html[data-package="light"] body {
  /* CORRECTION CRUCIALE : 
     On enlève le !important du body. 
     Cela permet aux sections (comme le Hero) d'afficher leur propre fond 
     et à la Navbar d'être réellement transparente.
  */
  background-color: transparent; 
  color: #0f172a !important;
  margin: 0;
  padding: 0;
}

/* ===== 3. MODE LIGHT FORCÉ (data-package="light") ===== */
html[data-package="light"] {
  color: #0f172a !important;
}

html[data-package="light"] body {
  background-color: #ffffff; /* Pas d'important ici */
  color: #0f172a !important;
  margin: 0;
  padding: 0;
}

/* La Navbar doit être PRIORITAIRE sur la transparence */
html[data-package="light"] nav {
  background-color: transparent !important; 
}

/* On force le blanc UNIQUEMENT sur les sections de contenu */
html[data-package="light"] section:not(.no-forced-bg),
html[data-package="light"] footer {
  background-color: #ffffff !important;
  color: #0f172a !important;
}

/* On retire le fond forcé du main pour qu'il laisse voir ce qu'il y a derrière (le Hero) */
html[data-package="light"] main {
  background-color: transparent !important;
}

/* ===== 4. VIGNETTES EN MODE SOMBRE ===== */
html.dark:not([data-package="light"]) .property-card,
html.dark:not([data-package="light"]) .bg-slate-50,
html.dark:not([data-package="light"]) .bg-gray-50 {
  background-color: #0f172a !important;
  border-color: rgba(255, 255, 255, 0.1) !important;
}

/* ===== 5. SCROLLBAR ===== */
::-webkit-scrollbar {
  width: 6px;
}
::-webkit-scrollbar-track {
  background: transparent;
}
::-webkit-scrollbar-thumb {
  background: var(--accent-gold);
  border-radius: 10px;
}

/* ===== 6. COMPOSANTS SPÉCIFIQUES ===== */
.dark .mobile-menu-link {
  color: #ffffff !important;
  opacity: 1 !important;
}

html[data-package="light"] .theme-toggle-component {
  display: none !important;
}

/* Badge Type (commun) */
.badge-type {
  background-color: rgba(0, 0, 0, 0.75) !important;
  color: #ffffff !important;
  backdrop-filter: blur(4px);
  border: 1px solid rgba(255, 255, 255, 0.3) !important;
}

/* Badge Référence - Mode Light */
.badge-ref-light {
  background-color: #000000 !important;
  color: #ffffff !important;
  border-color: rgba(255, 255, 255, 0.2) !important;
}

/* Badge Référence - Mode Dark */
.badge-ref-dark {
  background-color: #D4AF37 !important;
  color: #000000 !important;
  border-color: rgba(0, 0, 0, 0.1) !important;
}
