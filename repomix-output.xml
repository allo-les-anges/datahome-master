<file path="app/page.tsx">
"use client";

import { useState, useEffect, Suspense } from "react";
import { Loader2, Search, X } from "lucide-react";
import { SiteConfig } from "@/config/site-config";

// Import des composants épurés
import Navbar from "@/components/Navbar";
import Hero from "@/components/Hero";
import PropertyGrid from "@/components/PropertyGrid";
import Footer from "@/components/Footer";
import AdvancedSearch from "@/components/AdvancedSearch";

function HomeContent() {
  const [mounted, setMounted] = useState(false);
  const [allProperties, setAllProperties] = useState<any[]>([]);
  const [totalProperties, setTotalProperties] = useState(0);
  const [loading, setLoading] = useState(true);
  const [loadingMore, setLoadingMore] = useState(false);
  const [isSearchOpen, setIsSearchOpen] = useState(false);
  const [filters, setFilters] = useState({
    type: "", town: "", region: "", beds: "",
    minPrice: "", maxPrice: "", reference: "",
  });

  useEffect(() => {
    setMounted(true);
    loadProperties(0);
  }, []);

  const loadProperties = async (offset: number) => {
    try {
      if (offset === 0) setLoading(true);
      else setLoadingMore(true);

      // On utilise l'endpoint défini dans la config SaaS
      const res = await fetch(`/api/properties?limit=12&offset=${offset}`);
      const data = await res.json();
      const total = parseInt(res.headers.get('X-Total-Count') || '0');

      if (Array.isArray(data)) {
        setAllProperties(prev => offset === 0 ? data : [...prev, ...data]);
        setTotalProperties(total);
      }
    } catch (err) {
      console.error("Erreur flux XML:", err);
    } finally {
      setLoading(false);
      setLoadingMore(false);
    }
  };

  const handleSearch = (newFilters: any) => {
    setFilters({ ...filters, ...newFilters });
    setIsSearchOpen(false);
    document.getElementById("collection")?.scrollIntoView({ behavior: "smooth" });
  };

  if (!mounted) return null;

  return (
    <main className="min-h-screen bg-white font-sans overflow-x-hidden">
      <Navbar />
      
      {/* HERO SECTION DYNAMIQUE */}
      <section className="relative h-[70vh] flex flex-col items-center justify-center">
        <Hero 
          title={SiteConfig.hero.title} 
          subtitle={SiteConfig.hero.subtitle}
          backgroundImage={SiteConfig.hero.backgroundImage}
        />
        
        <div className="absolute bottom-[10%] z-40">
          <button 
            onClick={() => setIsSearchOpen(true)}
            className="flex items-center gap-4 px-8 py-4 bg-brand-primary text-white rounded-full hover:scale-105 transition-all shadow-lg"
          >
            <Search size={18} />
            <span className="text-xs font-bold uppercase tracking-widest">
              {SiteConfig.hero.ctaText}
            </span>
          </button>
        </div>
      </section>

      {/* GRILLE DE BIENS (COLLECTION) */}
      <section id="collection" className="py-20 bg-slate-50">
        <div className="max-w-7xl mx-auto px-6">
          <header className="mb-12 text-center">
            <h2 className="text-3xl md:text-5xl font-serif italic text-slate-900 mb-4">
              Notre Sélection
            </h2>
            <div className="w-20 h-1 bg-brand-primary mx-auto mb-6"></div>
            <p className="text-slate-500 text-[10px] font-bold uppercase tracking-[0.3em]">
              {totalProperties} Biens disponibles
            </p>
          </header>

          {loading ? (
            <div className="flex justify-center py-20">
              <Loader2 className="animate-spin text-brand-primary" size={40} />
            </div>
          ) : (
            <>
              <PropertyGrid properties={allProperties} isLight={true} />
              
              {allProperties.length < totalProperties && (
                <div className="flex justify-center mt-16">
                  <button
                    onClick={() => loadProperties(allProperties.length)}
                    disabled={loadingMore}
                    className="px-10 py-4 border-2 border-brand-primary text-brand-primary font-bold uppercase text-[10px] tracking-widest hover:bg-brand-primary hover:text-white transition-all disabled:opacity-50"
                  >
                    {loadingMore ? "Chargement..." : "Afficher plus de biens"}
                  </button>
                </div>
              )}
            </>
          )}
        </div>
      </section>

      {/* MODAL DE RECHERCHE */}
      {isSearchOpen && (
        <div className="fixed inset-0 z-[100] flex items-center justify-center p-4">
          <div className="absolute inset-0 bg-slate-900/80 backdrop-blur-sm" onClick={() => setIsSearchOpen(false)} />
          <div className="relative w-full max-w-4xl bg-white shadow-2xl rounded-2xl overflow-hidden">
            <button onClick={() => setIsSearchOpen(false)} className="absolute top-5 right-5 p-2 hover:bg-slate-100 rounded-full transition-all text-slate-900">
              <X size={24} />
            </button>
            <div className="p-8 md:p-12 max-h-[80vh] overflow-y-auto">
              <AdvancedSearch onSearch={handleSearch} isLight={true} />
            </div>
          </div>
        </div>
      )}

      <Footer />
    </main>
  );
}

export default function Home() {
  return (
    <Suspense fallback={<div className="h-screen flex items-center justify-center"><Loader2 className="animate-spin text-emerald-500" size={48} /></div>}>
      <HomeContent />
    </Suspense>
  );
}
</file>

