function boldify(s) { return s.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>'); }

function buildSteps(arr, color, t) {
  // Replace {new} {cont} {conv} tokens in step text
  return arr.map((s, i) => {
    let text = boldify(s);
    if (t && text.includes('{new}')) {
      text = text
        .replace('{new}',  `<span style="color:#60a5fa;font-weight:800">${t.s4statuses[0]}</span>`)
        .replace('{cont}', `<span style="color:#fbbf24;font-weight:800">${t.s4statuses[1]}</span>`)
        .replace('{conv}', `<span style="color:#4ade80;font-weight:800">${t.s4statuses[2]}</span>`);
    }
    return `<li class="step"><div class="sn" style="background:${color}">${i+1}</div><div class="st">${text}</div></li>`;
  }).join('');
}

